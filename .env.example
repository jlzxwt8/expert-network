# Production: DATABASE_URL, NEXTAUTH_URL, and AUTH_SECRET or NEXTAUTH_SECRET (32+ chars) are validated at startup.
# Auth.js v5 prefers AUTH_SECRET; NEXTAUTH_SECRET still works as an alias.
# Emergency bypass (not for Vercel): SKIP_ENV_VALIDATION=1
#
# Vercel CLI — push many vars at once: put KEY=value lines in `.env.vercel.sync` (gitignored), then:
#   npm run vercel:env:apply -- production ./.env.vercel.sync
# Requires `vercel link` + `vercel login`. Inspect names: `npm run vercel:env:ls`; pull down: `npm run vercel:env:pull`.

# Optional: mirror expert memories to Postgres pgvector (run admin/migrate on Postgres first; needs OPENAI_API_KEY for embeddings)
#USE_PGVECTOR_MEMORY=1
#PGVECTOR_DATABASE_URL="postgresql://..."  # defaults to DATABASE_URL when Postgres

# Optional: Inngest — register https://YOUR_DOMAIN/api/inngest in Inngest Cloud; set signing key on Vercel
#INNGEST_SIGNING_KEY=""
#INNGEST_EVENT_KEY=""
# When Inngest runs the daily remainder job, skip Vercel cron work:
#CRON_DELEGATED_TO_INNGEST=1

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/expert_network?schema=public"

# NextAuth / Auth.js v5
NEXTAUTH_URL="http://localhost:3000"
# Prefer AUTH_SECRET in new deployments; either must be 32+ characters in production.
AUTH_SECRET=""
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Magic Link)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@helpandgrow.network"

# AI Provider — "qwen" (default, Alibaba DashScope) | "dedalus" | "gemini" | "openai"
AI_PROVIDER="qwen"

# --- Gemini (required when AI_PROVIDER=gemini) ---
# Also needed for Google Search grounding & PDF extraction in qwen/openai modes.
#
# Option A: Vertex AI (recommended — uses GCP credits, higher quotas)
#   1. Enable Vertex AI API at console.cloud.google.com
#   2. Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
#
# Option B: AI Studio API key (simpler, free tier has limited image quota)
#   Get your key at https://aistudio.google.com
GEMINI_API_KEY=""

# --- Qwen / DashScope (required when AI_PROVIDER=qwen) ---
#   Get your key at https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=""

# --- OpenAI (required when AI_PROVIDER=openai) ---
#   Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Supabase Storage (optional)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Base chain + POMP (EAS attestations) ---
# RPC for server-side minting + webhooks (Vercel).
BASE_RPC_URL="https://mainnet.base.org"
# Issuer wallet (attester). No protocol fee — you pay Base gas only.
POMP_ISSUER_PRIVATE_KEY=""
# Register schema once: node scripts/register-pomp-eas-schema.mjs (or Base EASScan UI)
POMP_EAS_SCHEMA_UID=""
# Optional override; default is 0x4200000000000000000000000000000000000021 on Base / Base Sepolia.
EAS_CONTRACT_ADDRESS=""
# Alchemy webhook HMAC (Custom Webhook → your /api/webhook/onchain)
ALCHEMY_WEBHOOK_SECRET=""
# HiClaw session rows + on-chain sync (Next.js: tidb.ts) — Postgres only. Prefer HICLAW_POSTGRES_URL or DB9_DATABASE_URL.
# TIDB_DATABASE_URL is a legacy env name: only used if the value is postgres:// or postgresql:// (never mysql://).
TIDB_DATABASE_URL=""
DB9_DATABASE_URL=""
HICLAW_POSTGRES_URL=""
# HiClaw Node service: optional HTTP SQL instead of TCP (see hiclaw/README.md)
#DB9_HTTP_SQL_URL=""
#DB9_HTTP_SQL_TOKEN=""

# Public (browser) — H&G ERC-20 + EAS schema deep links on /reputation
NEXT_PUBLIC_HG_TOKEN_ADDRESS=""
NEXT_PUBLIC_POMP_EAS_SCHEMA_UID=""
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
