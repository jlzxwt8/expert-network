generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain Models ───

enum UserRole {
  EXPERT
  FOUNDER
  ADMIN
}

enum SessionType {
  ONLINE
  OFFLINE
  BOTH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OnboardingStep {
  SOCIAL_LINKS
  DOMAINS
  SESSION_PREFS
  AI_GENERATION
  PREVIEW
  PUBLISHED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  nickName      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(FOUNDER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  expert   Expert?
  bookingsAsFounder Booking[] @relation("FounderBookings")
  reviews  Review[]
}

model Expert {
  id              String         @id @default(cuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Social links
  linkedIn        String?
  twitter         String?
  substack        String?
  instagram       String?
  tiktok          String?
  xiaohongshu     String?

  // Professional info
  domains         ExpertDomain[]
  sessionType     SessionType    @default(BOTH)
  bio             String?        @db.LongText
  servicesOffered Json?

  // Uploaded document
  documentName    String?
  documentData    String?        @db.LongText

  // AI-generated content
  avatarVideoUrl  String?        @db.LongText
  avatarScript    String?        @db.LongText

  // Onboarding state
  onboardingStep  OnboardingStep @default(SOCIAL_LINKS)
  isPublished     Boolean        @default(false)
  isVerified      Boolean        @default(false)

  // Ratings
  avgRating       Float          @default(0)
  reviewCount     Int            @default(0)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  bookings        Booking[]
  reviews         Review[]
  availableSlots  AvailableSlot[]
}

model ExpertDomain {
  id       String @id @default(cuid())
  expertId String
  expert   Expert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  domain   String

  @@unique([expertId, domain])
  @@index([expertId])
}

model AvailableSlot {
  id        String   @id @default(cuid())
  expertId  String
  expert    Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([expertId, startTime])
}

model Booking {
  id          String        @id @default(cuid())
  expertId    String
  expert      Expert        @relation(fields: [expertId], references: [id], onDelete: Cascade)
  founderId   String
  founder     User          @relation("FounderBookings", fields: [founderId], references: [id], onDelete: Cascade)

  sessionType SessionType
  startTime   DateTime
  endTime     DateTime
  timezone    String        @default("Asia/Singapore")
  meetingLink String?
  status      BookingStatus @default(PENDING)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  review      Review?

  @@index([expertId, startTime])
  @@index([founderId])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  expertId  String
  expert    Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  founderId String
  founder   User     @relation(fields: [founderId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?  @db.Text

  createdAt DateTime @default(now())

  @@index([expertId])
  @@index([founderId])
  @@index([bookingId])
}
