# Session store: use ONE of TiDB (MySQL) OR Postgres (DB9 / Supabase-compatible URL).
# If HICLAW_POSTGRES_URL or DB9_DATABASE_URL is set, the service uses Postgres and ignores TIDB_DATABASE_URL.
# DB9: `db9 create` → connection string, then run hiclaw/schema-postgres.sql once.
#HICLAW_POSTGRES_URL="postgresql://user:pass@host:5432/expert_network"
#DB9_DATABASE_URL="postgresql://..."

# TiDB Cloud Zero — https://zero.tidbcloud.com/ (legacy; optional if Postgres is set)
TIDB_DATABASE_URL="mysql://user:password@gateway...tidbcloud.com:4000/expert_network?sslaccept=strict"

# DashScope (Alibaba Cloud) — Qwen-Max for shadow worker generation
DASHSCOPE_API_KEY="sk-your-dashscope-key"

# mem9 — persistent expert memory (no API key needed, uses space IDs)
MEM9_ENABLED="true"

# Evaluator loop (generator/evaluator harness)
EVALUATOR_ENABLED="true"
EVALUATOR_MIN_SCORE="7"
EVALUATOR_MAX_ROUNDS="3"

# Shadow context reset when estimated prompt tokens exceed ratio × window (qwen-max scale)
SHADOW_CONTEXT_WINDOW_TOKENS="32768"
SHADOW_CONTEXT_RESET_RATIO="0.7"

# Optional: POST draft JSON to your app; respond with { "hint": "..." } for evaluator (e.g. MCP availability).
#HICLAW_EVALUATOR_TOOL_URL="https://your-app/api/internal/evaluator-tools"
